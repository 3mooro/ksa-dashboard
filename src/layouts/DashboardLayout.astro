---
import { LayoutDashboard, Users, BookOpen, LogOut, Bell, Search } from 'lucide-astro';
import '../styles/global.css';

interface Props {
	title: string;
}
const { title } = Astro.props;
---
<html lang="ar" dir="rtl">
<head>
	<meta charset="utf-8" />
	<title>{title} | لوحة تحكم أكاديمية KSA</title>
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
	<style>body { font-family: 'Cairo', sans-serif; }</style>
</head>
<body class="bg-slate-50 flex h-screen overflow-hidden text-slate-800">
	
	<!-- القائمة الجانبية (Sidebar) -->
	<aside class="w-72 bg-slate-950 text-slate-300 flex flex-col shadow-2xl z-20">
		<div class="h-20 flex items-center px-8 border-b border-slate-800/50">
			<div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center text-white font-black text-xl ml-3 shadow-lg shadow-blue-600/20">K</div>
			<span class="text-2xl font-black text-white tracking-tight">أكاديمية KSA</span>
		</div>
		
		<nav class="flex-1 px-4 py-8 space-y-2 overflow-y-auto">
			<p class="px-4 text-xs font-bold text-slate-500 uppercase tracking-wider mb-4">لوحة القيادة</p>
			
			<a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-800/50 hover:text-white transition-all font-bold group border-r-4 border-transparent hover:border-slate-500">
				<LayoutDashboard class="w-5 h-5" /> <span>نظرة عامة</span>
			</a>
			<a href="/courses" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-800/50 hover:text-white transition-all font-bold group border-r-4 border-transparent hover:border-slate-500">
				<BookOpen class="w-5 h-5 group-hover:text-blue-400 transition-colors" /> <span>إدارة الكورسات</span>
			</a>
			<a href="/blog" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-800/50 hover:text-white transition-all font-bold group border-r-4 border-transparent hover:border-slate-500">
				<BookOpen class="w-5 h-5 group-hover:text-blue-400 transition-colors" /> <span>إدارة المقالات</span>
			</a>
			<a href="/students" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-800/50 hover:text-white transition-all font-bold group border-r-4 border-transparent hover:border-slate-500">
				<Users class="w-5 h-5 group-hover:text-blue-400 transition-colors" /> <span>إدارة الطلبات</span>
			</a>
		</nav>

		<div class="p-4 border-t border-slate-800/50">
			<form method="POST" action="/api/logout">
				<button type="submit" class="flex items-center gap-3 px-4 py-3 w-full rounded-xl text-slate-400 hover:bg-red-500/10 hover:text-red-400 transition-all font-bold">
					<LogOut class="w-5 h-5" /> <span>تسجيل خروج</span>
				</button>
			</form>
		</div>
	</aside>

	<!-- المحتوى الرئيسي (Main Content) -->
	<main class="flex-1 flex flex-col h-screen overflow-hidden relative">
		<!-- شريط التنقل العلوي -->
		<header class="h-20 bg-white/80 backdrop-blur-md border-b border-slate-200 flex items-center justify-between px-8 sticky top-0 z-10">
			<div class="flex items-center gap-4 w-96">
				<div class="relative w-full group">
					<Search class="absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 group-focus-within:text-blue-600 transition-colors" />
					<input type="text" placeholder="بحث سريع عن طالب أو كورس..." class="w-full bg-slate-100 border-none rounded-full py-2.5 pr-10 pl-4 text-sm font-bold focus:ring-2 focus:ring-blue-500/20 focus:bg-white outline-none transition-all shadow-inner" />
				</div>
			</div>
			
			<div class="flex items-center gap-6">
				<button class="relative text-slate-400 hover:text-blue-600 transition-colors">
					<Bell class="w-6 h-6" />
					<span class="absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full border-2 border-white"></span>
				</button>
				<div class="w-px h-8 bg-slate-200"></div>
				<div class="flex items-center gap-3 cursor-pointer">
					<div class="text-left hidden md:block">
						<p class="text-sm font-black text-slate-800">المدير العام</p>
						<p class="text-xs font-bold text-slate-500">Omar Admin</p>
					</div>
					<img src="https://i.pravatar.cc/150?u=admin" class="w-10 h-10 rounded-full border-2 border-slate-200" alt="Admin" />
				</div>
			</div>
		</header>
		
		<!-- منطقة العمل (Page Content) -->
		<div class="flex-1 overflow-auto p-8">
			<slot />
		</div>
	</main>
</body>
</html>
