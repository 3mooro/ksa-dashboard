---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { Plus, Edit2, Trash2 } from 'lucide-astro';
import { env } from 'cloudflare:workers';

let posts = [];

try {
	const db = env.DB;
	const { results } = await db.prepare("SELECT * FROM blog ORDER BY pubDate DESC, created_at DESC").all();
	if (results) {
		posts = results;
	}
} catch (e) {
	console.error("Database connection error:", e);
}
---

<DashboardLayout title="إدارة المقالات">
	<div class="flex justify-between items-center mb-8">
		<div>
			<h2 class="text-3xl font-black text-slate-800">إدارة المقالات (المدونة)</h2>
			<p class="text-slate-500 font-bold mt-1">أضف مقالات جديدة لجذب الزوار وتصدر محركات البحث.</p>
		</div>
		<a href="/blog/add" class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-5 py-3 rounded-xl font-bold transition-all shadow-md shadow-blue-600/20 hover:-translate-y-0.5">
			<Plus class="w-5 h-5" /> إضافة مقال جديد
		</a>
	</div>

	<div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
		<div class="overflow-x-auto">
			<table class="w-full text-right">
				<thead>
					<tr class="bg-slate-50/50 border-b border-slate-100 text-slate-500 text-sm font-bold">
						<th class="px-6 py-4">عنوان المقال</th>
						<th class="px-6 py-4">الكاتب</th>
						<th class="px-6 py-4">تاريخ النشر</th>
						<th class="px-6 py-4 text-center">الإجراءات</th>
					</tr>
				</thead>
				<tbody>
					{posts.length === 0 ? (
						<tr>
							<td colspan="4" class="px-6 py-12 text-center text-slate-400 font-bold">
								لا توجد مقالات مضافة حالياً.
							</td>
						</tr>
					) : (
						posts.map((post) => (
							<tr class="border-b border-slate-50 hover:bg-slate-50/50 transition-colors">
								<td class="px-6 py-4 font-bold text-slate-800">
									<div class="line-clamp-1">{post.title}</div>
								</td>
								<td class="px-6 py-4 text-sm text-slate-600">{post.author}</td>
								<td class="px-6 py-4 text-sm text-slate-500" dir="ltr">
									{post.pubDate ? new Date(post.pubDate).toLocaleDateString('ar-EG') : '-'}
								</td>
								<td class="px-6 py-4 flex items-center justify-center gap-3">
									<a href={`/blog/add?id=${post.id}`} class="text-blue-500 hover:text-blue-700 bg-blue-50 hover:bg-blue-100 p-2 rounded-lg transition-colors" title="تعديل">
										<Edit2 class="w-4 h-4" />
									</a>
									<form method="POST" action="/api/blog/delete" class="inline" onsubmit="return confirm('هل أنت متأكد من حذف هذا المقال؟ لا يمكن التراجع عن هذا الإجراء.');">
										<input type="hidden" name="id" value={post.id} />
										<button type="submit" class="text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 p-2 rounded-lg transition-colors" title="حذف">
											<Trash2 class="w-4 h-4" />
										</button>
									</form>
								</td>
							</tr>
						))
					)}
				</tbody>
			</table>
		</div>
	</div>
</DashboardLayout>
